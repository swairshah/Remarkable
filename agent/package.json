{
  "name": "rbot",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "flue dev --target node",
    "connect": "flue connect rbot default --target node",
    "build": "flue build --target node",
    "typecheck": "tsc --noEmit",
    "test": "node --test test/*.test.ts",
    "smoke": "printf \"Reply with exactly OK.\\n\" | flue connect rbot smoke --target node"
  },
  "dependencies": {
    "@earendil-works/pi-ai": "^0.79.10",
    "@flue/runtime": "^0.11.1",
    "hono": "^4.12.27"
  },
  "devDependencies": {
    "@flue/cli": "^0.11.1",
    "typescript": "^5.4.0"
  }
}
