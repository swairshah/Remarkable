+namespace {
+// Whiten the padding border around the terminal cell area.
+void
+clearPadding(rmlib::Canvas& canvas, int pad) {
+  if (pad <= 0) {
+    return;
+  }
+  const auto full = canvas.rect();
+  canvas.set(Rect{ full.topLeft, { full.bottomRight.x, pad - 1 } }, white);
+  canvas.set(
+    Rect{ { full.topLeft.x, full.bottomRight.y - pad + 1 }, full.bottomRight },
+    white);
+  canvas.set(Rect{ full.topLeft, { pad - 1, full.bottomRight.y } }, white);
+  canvas.set(
+    Rect{ { full.bottomRight.x - pad + 1, full.topLeft.y }, full.bottomRight },
+    white);
+}
